---
import Layout from '../layouts/Layout.astro';

const topics = [
    {
        title: "タイピングゲーム",
        description: "正しい運指を身につける！指ごと・段ごと・ローマ字の3モードで楽しく練習",
        icon: "⌨️",
        link: "/typing-game",
        color: "from-violet-500 to-indigo-600"
    },
    {
        title: "プログラミングレッスン",
        description: "Pythonのコードを実際に実行しながら学習できるレッスン",
        icon: "💻",
        link: "/programming-lessons",
        color: "from-blue-500 to-purple-600"
    },
    {
        title: "問題演習",
        description: "様々な情報学の問題を解いて理解を深めるツール",
        icon: "📝",
        link: "/quiz",
        color: "from-emerald-500 to-teal-600"
    },
    {
        title: "2進数・10進数変換",
        description: "2進数と10進数の相互変換を学習できるツール",
        icon: "🔢",
        link: "/binary-converter",
        color: "from-blue-500 to-purple-600"
    },
    {
        title: "16進数学習",
        description: "16進数の基本概念と他の進数との変換を学習",
        icon: "🔠",
        link: "/hex-converter",
        color: "from-purple-500 to-indigo-600"
    },
    {
        title: "2進数・10進数・16進数",
        description: "2進数・10進数・16進数の変換と理解を深めるツール",
        icon: "⚡",
        link: "/binary-simulator",
        color: "from-blue-500 to-cyan-600"
    },
    {
        title: "24ビットフルカラー",
        description: "24ビットフルカラーとRGB・CMYKの学習ツール",
        icon: "🎨",
        link: "/color-simulator",
        color: "from-green-500 to-teal-600"
    },
    {
        title: "論理式",
        description: "論理式から論理回路や真理値表を作成します",
        icon: "🔄",
        link: "/logical-formula",
        color: "from-purple-500 to-pink-600"
    },
    {
        title: "スマホ対応論理回路シミュレータ",
        description: "インタラクティブな論理回路の設計・シミュレーション",
        icon: "⚡",
        link: "/mobile-circuit-simulator",
        color: "from-indigo-500 to-blue-600"
    },
    {
        title: "データ圧縮",
        description: "ランレングス符号化・ハフマン符号化を学習できます",
        icon: "📦",
        link: "/data-compression",
        color: "from-orange-500 to-red-600"
    },
    {
        title: "Python学習",
        description: "ブラウザ上でPythonコードを実行して学習できます",
        icon: "🐍",
        link: "/python-playground",
        color: "from-emerald-500 to-cyan-600"
    },
    {
        title: "Markdownエディタ",
        description: "リアルタイムプレビュー・自動保存対応のMarkdownエディタ",
        icon: "📝",
        link: "/markdown-editor",
        color: "from-violet-500 to-purple-600"
    },
    {
        title: "ネットワーク通信",
        description: "HTTP通信やDNS解決の仕組みを視覚的に学習できます",
        icon: "🌐",
        link: "/network-simulator",
        color: "from-blue-500 to-indigo-600"
    },
    {
        title: "画像デジタル化",
        description: "画像の解像度、ピクセル、ファイルサイズの関係を体験的に学習",
        icon: "📸",
        link: "/image-digitization",
        color: "from-pink-500 to-rose-600"
    },
    {
        title: "データベース正規化",
        description: "ドラッグ&ドロップで直感的にデータベースの正規化を学習",
        icon: "🗄️",
        link: "/database-simulator",
        color: "from-indigo-500 to-purple-600"
    },
    {
        title: "Whois検索",
        description: "ドメイン名やIPアドレスの登録情報・管理者情報を検索",
        icon: "🔍",
        link: "/whois-lookup",
        color: "from-teal-500 to-cyan-600"
    },
    {
        title: "生成AI活用",
        description: "情報Ⅰの学習に役立つ生成AI用プロンプトテンプレート集",
        icon: "🤖",
        link: "/ai-prompts",
        color: "from-purple-500 to-pink-600"
    }
];

---

<Layout 
    title="じょうほうらいふ - 情報Ⅰ勉強・教材・問題演習サイト" 
    description="じょうほうらいふは高校生のための情報Ⅰ学習支援サイトです。情報Ⅰの勉強、教材、問題演習を効果的にサポート。2進数変換、アルゴリズム、データ構造、著作権、プログラミング学習など、情報Ⅰの全範囲を網羅した無料の学習ツールを提供。"
    keywords="じょうほうらいふ,情報Ⅰ,情報Ⅰ 勉強,情報Ⅰ 教材,情報Ⅰ 問題,情報Ⅰ 過去問,高校情報,プログラミング学習,2進数変換,アルゴリズム,データ構造,著作権,産業財産権,論理回路,情報処理,コンピュータサイエンス"
>
    <section class="topics-section">
        <div class="section-header">
            <h2>情報Ⅰの学習コンテンツ</h2>
            <p>情報Ⅰの勉強に必要な主要なトピックをカバーした教材と問題演習を提供しています</p>
        </div>
        
        <div class="learning-grid">
            {topics.map(topic => (
                <a href={topic.link} class="topic-card-link">
                    <div class={`topic-card bg-gradient-to-br ${topic.color}`}>
                        <div class="topic-icon">{topic.icon}</div>
                        <h3>{topic.title}</h3>
                        <p>{topic.description}</p>
                        <div class="topic-arrow">→</div>
                    </div>
                </a>
            ))}
        </div>
    </section>

</Layout>

<style>
.hero-section {
    text-align: center;
    padding: 4rem 0 6rem;
    background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    border-radius: 2rem;
    margin-bottom: 4rem;
    position: relative;
    overflow: hidden;
}

.hero-section::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.05) 0%, transparent 70%);
    animation: float 20s ease-in-out infinite;
}

@keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(2deg); }
}

.hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
}

.hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.1;
}

.highlight {
    background: linear-gradient(135deg, #3b82f6, #10b981);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    position: relative;
}

.hero-description {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    line-height: 1.6;
}

.hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
}

.btn-large {
    padding: 1rem 2rem;
    font-size: 1.125rem;
}

.hero-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 2rem;
    max-width: 600px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
}

.stat-item {
    text-align: center;
}

.stat-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--primary-color);
    line-height: 1;
}

.stat-label {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
}

.topics-section {
    margin-bottom: 6rem;
}

.section-header {
    text-align: center;
    margin-bottom: 3rem;
}

.section-header h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
}

.section-header p {
    font-size: 1.125rem;
    color: var(--text-secondary);
}

.topic-card-link {
    text-decoration: none;
    display: block;
    transition: transform 0.3s ease;
}

.topic-card {
    height: 100%;
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    color: white;
    transition: all 0.3s ease;
}

.topic-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
}

.topic-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    display: block;
}

.topic-card h3 {
    color: white;
    font-size: 1.5rem;
    margin-bottom: 1rem;
}

.topic-card p {
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 1.5rem;
}

.topic-arrow {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    font-size: 1.5rem;
    font-weight: bold;
    opacity: 0.7;
    transition: all 0.3s ease;
}

.topic-card:hover .topic-arrow {
    transform: translateX(0.5rem);
    opacity: 1;
}

.learning-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
}

/* レスポンシブ対応 */
@media (max-width: 768px) {
    .hero-title {
        font-size: 2.5rem;
    }
    
    .hero-description {
        font-size: 1.125rem;
    }
    
    .hero-buttons {
        flex-direction: column;
        align-items: center;
    }
    
    .hero-stats {
        gap: 1.5rem;
    }
    
    .stat-number {
        font-size: 2rem;
    }
    
    .section-header h2 {
        font-size: 2rem;
    }
    
    .topic-card {
        padding: 2rem;
    }
    
}
</style>